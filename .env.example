# Kopie nach `.env` anlegen und Werte anpassen: cp .env.example .env

# Dashboard-Passwort (Login & Admin-Aktionen wie Zonen-Nullung)
DASHBOARD_PASSWORD=changeme

# MQTT-Broker-Zugangsdaten — werden sowohl von der Server-App als auch von den
# ESP32-Sensoren verwendet. Beim Start des mosquitto-Containers wird daraus die
# Passwortdatei generiert.
MQTT_USERNAME=peoplepassage
MQTT_PASSWORD=changeme-mqtt

# pretix-Checkin-Integration (optional) — wenn alle fünf Werte gesetzt sind, fragt
# der Server periodisch die laut Ticketkontrolle aktuell anwesende Gesamtzahl ab und
# zeigt die Differenz zur Summe aller TOF-Zonen als berechnete "Restgelände"-Zone an.
# Leer lassen, um die Integration deaktiviert zu lassen.
PRETIX_BASE_URL=
PRETIX_API_TOKEN=
PRETIX_ORGANIZER=
PRETIX_EVENT=
PRETIX_CHECKINLIST_ID=
PRETIX_POLL_INTERVAL_S=30
PRETIX_REMAINDER_ZONE_NAME=Restgelände
